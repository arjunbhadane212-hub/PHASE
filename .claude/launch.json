{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["--cwd", "frontend", "start"],
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && uvicorn server:app --reload --port 8001"],
      "port": 8001
    }
  ]
}
